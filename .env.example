# Orion Harness — exemplo de variaveis de ambiente.
# Copie para .env (NUNCA versionado) e preencha. Segredos reais ficam em
# secret manager / GitHub Secrets em CI. Ver docs/runbooks/secrets.md.

# --- Aplicacao ---
APP_ENV=development            # development | staging | production
LOG_LEVEL=info                 # debug | info | warn | error

# --- Exemplos (remova/ajuste conforme o projeto) ---
# DATABASE_URL=
# API_BASE_URL=
# JWT_SECRET=                  # nunca commitar o valor real
# OTEL_EXPORTER_OTLP_ENDPOINT= # observabilidade (opt-in)
