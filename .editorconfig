# Orion Harness — convenção base de edição (universal, poliglota)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.{py,go,rs}]
indent_size = 4

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # preserva quebras de linha "hard break"

[Makefile]
indent_style = tab
