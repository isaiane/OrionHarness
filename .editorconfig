# Orion Harness — convenção base de edição (universal, poliglota)
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
# Sem max_line_length global: o limite de linha é enforçado pelos formatters por
# stack (prettier printWidth=100, ruff line-length=100), não por um checker de prosa.

[*.{py,go,rs}]
indent_size = 4

[*.go]
indent_style = tab

[*.md]
trim_trailing_whitespace = false  # preserva quebras de linha "hard break"
indent_size = unset               # prosa tem indentação irregular (listas aninhadas, mermaid)
indent_style = unset

# Shell scripts podem embutir heredocs de outras linguagens (indentação não uniforme).
[*.sh]
indent_size = unset

[Makefile]
indent_style = tab
